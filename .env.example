# 礼有方小程序环境变量示例
# 真实值放到 .env（git ignore）

# 应用环境
APP_ENV=development

# 后端 API base URL（MVP mock，留空走本地 mock）
API_BASE=

# 微信小程序 AppID（占位，真实值不入仓）
WX_APPID_PLACEHOLDER=

# 小程序 AppSecret（占位）
WX_APPSECRET_PLACEHOLDER=

# AI 提供商（MVP mock）
AI_PROVIDER=mock
AI_MODEL=giftpilot-v0
AI_GATEWAY_TRACE=1

# 平台 tag 升级提示
ROCKCENT_PLATFORM_TAG=platform-v1.15.2
